library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity alu8 is
  port(
    a      : in  std_logic_vector(7 downto 0);
    b      : in  std_logic_vector(7 downto 0);
    ctrl   : in  std_logic_vector(2 downto 0); -- like your slide: 000 AND,001 OR,010 ADD,110 SUB,111 SLT
    result : out std_logic_vector(7 downto 0);
    zero   : out std_logic
  );
end entity;

architecture rtl of alu8 is
  signal res : std_logic_vector(7 downto 0);
  signal as  : signed(7 downto 0);
  signal bs  : signed(7 downto 0);
begin
  as <= signed(a);
  bs <= signed(b);

  process(a,b,ctrl,as,bs)
  begin
    case ctrl is
      when "000" => res <= a and b;
      when "001" => res <= a or b;
      when "010" => res <= std_logic_vector(unsigned(a) + unsigned(b));
      when "110" => res <= std_logic_vector(unsigned(a) - unsigned(b));
      when "111" =>
        if as < bs then res <= (7 downto 1 => '0') & '1';
        else            res <= (others => '0');
        end if;
      when others =>
        res <= (others => '0');
    end case;
  end process;

  result <= res;
  zero <= '1' when res = x"00" else '0';
end architecture;