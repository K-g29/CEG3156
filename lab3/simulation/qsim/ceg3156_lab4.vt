		( WriteData_Out_expected_prev[0] !== 1'bx ) && ( WriteData_Out_prev[0] !== WriteData_Out_expected_prev[0] )
		&& ((WriteData_Out_expected_prev[0] !== last_WriteData_Out_exp[0]) ||
			on_first_change[38])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port WriteData_Out[0] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", WriteData_Out_expected_prev);
		$display ("     Real value = %b", WriteData_Out_prev);
		nummismatches = nummismatches + 1;
		on_first_change[38] = 1'b0;
		last_WriteData_Out_exp[0] = WriteData_Out_expected_prev[0];
	end
	if (
		( WriteData_Out_expected_prev[1] !== 1'bx ) && ( WriteData_Out_prev[1] !== WriteData_Out_expected_prev[1] )
		&& ((WriteData_Out_expected_prev[1] !== last_WriteData_Out_exp[1]) ||
			on_first_change[38])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port WriteData_Out[1] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", WriteData_Out_expected_prev);
		$display ("     Real value = %b", WriteData_Out_prev);
		nummismatches = nummismatches + 1;
		on_first_change[38] = 1'b0;
		last_WriteData_Out_exp[1] = WriteData_Out_expected_prev[1];
	end
	if (
		( WriteData_Out_expected_prev[2] !== 1'bx ) && ( WriteData_Out_prev[2] !== WriteData_Out_expected_prev[2] )
		&& ((WriteData_Out_expected_prev[2] !== last_WriteData_Out_exp[2]) ||
			on_first_change[38])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port WriteData_Out[2] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", WriteData_Out_expected_prev);
		$display ("     Real value = %b", WriteData_Out_prev);
		nummismatches = nummismatches + 1;
		on_first_change[38] = 1'b0;
		last_WriteData_Out_exp[2] = WriteData_Out_expected_prev[2];
	end
	if (
		( WriteData_Out_expected_prev[3] !== 1'bx ) && ( WriteData_Out_prev[3] !== WriteData_Out_expected_prev[3] )
		&& ((WriteData_Out_expected_prev[3] !== last_WriteData_Out_exp[3]) ||
			on_first_change[38])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port WriteData_Out[3] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", WriteData_Out_expected_prev);
		$display ("     Real value = %b", WriteData_Out_prev);
		nummismatches = nummismatches + 1;
		on_first_change[38] = 1'b0;
		last_WriteData_Out_exp[3] = WriteData_Out_expected_prev[3];
	end
	if (
		( WriteData_Out_expected_prev[4] !== 1'bx ) && ( WriteData_Out_prev[4] !== WriteData_Out_expected_prev[4] )
		&& ((WriteData_Out_expected_prev[4] !== last_WriteData_Out_exp[4]) ||
			on_first_change[38])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port WriteData_Out[4] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", WriteData_Out_expected_prev);
		$display ("     Real value = %b", WriteData_Out_prev);
		nummismatches = nummismatches + 1;
		on_first_change[38] = 1'b0;
		last_WriteData_Out_exp[4] = WriteData_Out_expected_prev[4];
	end
	if (
		( WriteData_Out_expected_prev[5] !== 1'bx ) && ( WriteData_Out_prev[5] !== WriteData_Out_expected_prev[5] )
		&& ((WriteData_Out_expected_prev[5] !== last_WriteData_Out_exp[5]) ||
			on_first_change[38])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port WriteData_Out[5] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", WriteData_Out_expected_prev);
		$display ("     Real value = %b", WriteData_Out_prev);
		nummismatches = nummismatches + 1;
		on_first_change[38] = 1'b0;
		last_WriteData_Out_exp[5] = WriteData_Out_expected_prev[5];
	end
	if (
		( WriteData_Out_expected_prev[6] !== 1'bx ) && ( WriteData_Out_prev[6] !== WriteData_Out_expected_prev[6] )
		&& ((WriteData_Out_expected_prev[6] !== last_WriteData_Out_exp[6]) ||
			on_first_change[38])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port WriteData_Out[6] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", WriteData_Out_expected_prev);
		$display ("     Real value = %b", WriteData_Out_prev);
		nummismatches = nummismatches + 1;
		on_first_change[38] = 1'b0;
		last_WriteData_Out_exp[6] = WriteData_Out_expected_prev[6];
	end
	if (
		( WriteData_Out_expected_prev[7] !== 1'bx ) && ( WriteData_Out_prev[7] !== WriteData_Out_expected_prev[7] )
		&& ((WriteData_Out_expected_prev[7] !== last_WriteData_Out_exp[7]) ||
			on_first_change[38])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port WriteData_Out[7] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", WriteData_Out_expected_prev);
		$display ("     Real value = %b", WriteData_Out_prev);
		nummismatches = nummismatches + 1;
		on_first_change[38] = 1'b0;
		last_WriteData_Out_exp[7] = WriteData_Out_expected_prev[7];
	end
	if (
		( ZeroOut_expected_prev !== 1'bx ) && ( ZeroOut_prev !== ZeroOut_expected_prev )
		&& ((ZeroOut_expected_prev !== last_ZeroOut_exp) ||
			on_first_change[39])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port ZeroOut :: @time = %t",  $realtime);
		$display ("     Expected value = %b", ZeroOut_expected_prev);
		$display ("     Real value = %b", ZeroOut_prev);
		nummismatches = nummismatches + 1;
		on_first_change[39] = 1'b0;
		last_ZeroOut_exp = ZeroOut_expected_prev;
	end

	trigger <= ~trigger;
end
initial 

begin 
$timeformat(-12,3," ps",6);
#1000000;
if (nummismatches > 0)
	$display ("%d mismatched vectors : Simulation failed !",nummismatches);
else
	$display ("Simulation passed !");
$finish;
end 
endmodule

module pipelinedProc_vlg_vec_tst();
// constants                                           
// general purpose registers
reg GClock;
reg GResetBar;
// wires                                               
wire [7:0] ALUResult_Out;
wire BranchOut;
wire [7:0] CtrlPack_Out;
wire [7:0] Dbg_A_fwd;
wire [7:0] Dbg_ALUInB_EX;
wire [7:0] Dbg_B_fwd;
wire Dbg_EXMEM_MemtoReg;
wire Dbg_EXMEM_MemWrite;
wire Dbg_EXMEM_RegWrite;
wire [2:0] Dbg_EXMEM_WriteReg;
wire [1:0] Dbg_ForwardA;
wire [1:0] Dbg_ForwardB;
wire [2:0] Dbg_ID_rs3;
wire [2:0] Dbg_ID_rt3;
wire Dbg_IDEX_Flush;
wire [2:0] Dbg_IDEX_Rt;
wire Dbg_IFID_Flush;
wire Dbg_IFID_Write;
wire Dbg_LoadUseFlush;
wire Dbg_MemRead_EX;
wire [7:0] Dbg_MEMWB_ALUResult;
wire [7:0] Dbg_MEMWB_MemReadData;
wire Dbg_MEMWB_MemtoReg;
wire Dbg_MEMWB_RegWrite;
wire [2:0] Dbg_MEMWB_WriteReg;
wire Dbg_PCWrite;
wire [7:0] Dbg_WD_WB;
wire [31:0] InstructionOut1;
wire [31:0] InstructionOut2;
wire [31:0] InstructionOut3;
wire [31:0] InstructionOut4;
wire [31:0] InstructionOut5;
wire MemWriteOut;
wire [7:0] PC_Out;
wire [7:0] ReadData1_Out;
wire [7:0] ReadData2_Out;
wire RegWriteOut;
wire [7:0] WriteData_Out;
wire ZeroOut;

wire sampler;                             

// assign statements (if any)                          
pipelinedProc i1 (
// port map - connection between master ports and signals/registers   
	.ALUResult_Out(ALUResult_Out),
	.BranchOut(BranchOut),
	.CtrlPack_Out(CtrlPack_Out),
	.Dbg_A_fwd(Dbg_A_fwd),
	.Dbg_ALUInB_EX(Dbg_ALUInB_EX),
	.Dbg_B_fwd(Dbg_B_fwd),
	.Dbg_EXMEM_MemtoReg(Dbg_EXMEM_MemtoReg),
	.Dbg_EXMEM_MemWrite(Dbg_EXMEM_MemWrite),
	.Dbg_EXMEM_RegWrite(Dbg_EXMEM_RegWrite),
	.Dbg_EXMEM_WriteReg(Dbg_EXMEM_WriteReg),
	.Dbg_ForwardA(Dbg_ForwardA),
	.Dbg_ForwardB(Dbg_ForwardB),
	.Dbg_ID_rs3(Dbg_ID_rs3),
	.Dbg_ID_rt3(Dbg_ID_rt3),
	.Dbg_IDEX_Flush(Dbg_IDEX_Flush),
	.Dbg_IDEX_Rt(Dbg_IDEX_Rt),
	.Dbg_IFID_Flush(Dbg_IFID_Flush),
	.Dbg_IFID_Write(Dbg_IFID_Write),
	.Dbg_LoadUseFlush(Dbg_LoadUseFlush),
	.Dbg_MemRead_EX(Dbg_MemRead_EX),
	.Dbg_MEMWB_ALUResult(Dbg_MEMWB_ALUResult),
	.Dbg_MEMWB_MemReadData(Dbg_MEMWB_MemReadData),
	.Dbg_MEMWB_MemtoReg(Dbg_MEMWB_MemtoReg),
	.Dbg_MEMWB_RegWrite(Dbg_MEMWB_RegWrite),
	.Dbg_MEMWB_WriteReg(Dbg_MEMWB_WriteReg),
	.Dbg_PCWrite(Dbg_PCWrite),
	.Dbg_WD_WB(Dbg_WD_WB),
	.GClock(GClock),
	.GResetBar(GResetBar),
	.InstructionOut1(InstructionOut1),
	.InstructionOut2(InstructionOut2),
	.InstructionOut3(InstructionOut3),
	.InstructionOut4(InstructionOut4),
	.InstructionOut5(InstructionOut5),
	.MemWriteOut(MemWriteOut),
	.PC_Out(PC_Out),
	.ReadData1_Out(ReadData1_Out),
	.ReadData2_Out(ReadData2_Out),
	.RegWriteOut(RegWriteOut),
	.WriteData_Out(WriteData_Out),
	.ZeroOut(ZeroOut)
);

// GClock
always
begin
	GClock = 1'b0;
	GClock = #12500 1'b1;
	#12500;
end 

// GResetBar
initial
begin
	GResetBar = 1'b1;
end 

pipelinedProc_vlg_sample_tst tb_sample (
	.GClock(GClock),
	.GResetBar(GResetBar),
	.sampler_tx(sampler)
);

pipelinedProc_vlg_check_tst tb_out(
	.ALUResult_Out(ALUResult_Out),
	.BranchOut(BranchOut),
	.CtrlPack_Out(CtrlPack_Out),
	.Dbg_A_fwd(Dbg_A_fwd),
	.Dbg_ALUInB_EX(Dbg_ALUInB_EX),
	.Dbg_B_fwd(Dbg_B_fwd),
	.Dbg_EXMEM_MemtoReg(Dbg_EXMEM_MemtoReg),
	.Dbg_EXMEM_MemWrite(Dbg_EXMEM_MemWrite),
	.Dbg_EXMEM_RegWrite(Dbg_EXMEM_RegWrite),
	.Dbg_EXMEM_WriteReg(Dbg_EXMEM_WriteReg),
	.Dbg_ForwardA(Dbg_ForwardA),
	.Dbg_ForwardB(Dbg_ForwardB),
	.Dbg_ID_rs3(Dbg_ID_rs3),
	.Dbg_ID_rt3(Dbg_ID_rt3),
	.Dbg_IDEX_Flush(Dbg_IDEX_Flush),
	.Dbg_IDEX_Rt(Dbg_IDEX_Rt),
	.Dbg_IFID_Flush(Dbg_IFID_Flush),
	.Dbg_IFID_Write(Dbg_IFID_Write),
	.Dbg_LoadUseFlush(Dbg_LoadUseFlush),
	.Dbg_MemRead_EX(Dbg_MemRead_EX),
	.Dbg_MEMWB_ALUResult(Dbg_MEMWB_ALUResult),
	.Dbg_MEMWB_MemReadData(Dbg_MEMWB_MemReadData),
	.Dbg_MEMWB_MemtoReg(Dbg_MEMWB_MemtoReg),
	.Dbg_MEMWB_RegWrite(Dbg_MEMWB_RegWrite),
	.Dbg_MEMWB_WriteReg(Dbg_MEMWB_WriteReg),
	.Dbg_PCWrite(Dbg_PCWrite),
	.Dbg_WD_WB(Dbg_WD_WB),
	.InstructionOut1(InstructionOut1),
	.InstructionOut2(InstructionOut2),
	.InstructionOut3(InstructionOut3),
	.InstructionOut4(InstructionOut4),
	.InstructionOut5(InstructionOut5),
	.MemWriteOut(MemWriteOut),
	.PC_Out(PC_Out),
	.ReadData1_Out(ReadData1_Out),
	.ReadData2_Out(ReadData2_Out),
	.RegWriteOut(RegWriteOut),
	.WriteData_Out(WriteData_Out),
	.ZeroOut(ZeroOut),
	.sampler_rx(sampler)
);
endmodule

